{
  "name": "agent-ci-monorepo",
  "private": true,
  "scripts": {
    "test": "pnpm --filter '!derive' -r test",
    "check": "npm-run-all --parallel typecheck lint format:check",
    "check:fix": "npm-run-all --parallel typecheck lint:fix format:fix",
    "typecheck": "pnpm -r run typecheck",
    "lint": "oxlint --deny-warnings",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:fix": "oxfmt",
    "format:check": "oxfmt --check",
    "agent-ci-dev": "cd packages/dtu-github-actions && pnpm run build && cd ../cli && tsx src/cli.ts",
    "start": "./scripts/run.sh",
    "prepare": "husky",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm -r build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@nkzw/oxlint-config": "1.0.1",
    "@types/node": "^25.3.0",
    "@typescript/native-preview": "7.0.0-dev.20260219.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "npm-run-all2": "8.0.4",
    "oxfmt": "0.33.0",
    "oxlint": "1.48.0",
    "tsx": "^4.21.0",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,md,yml,yaml,css,html}": [
      "oxfmt --check"
    ],
    "*.{js,ts,jsx,tsx}": [
      "oxlint --deny-warnings"
    ]
  },
  "packageManager": "pnpm@10.30.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}

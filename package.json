{
  "name": "oa-1",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others --names \"GitHub,Bridge,Runner\" \"pnpm --filter dtu-github-actions dev\" \"wait-on http://localhost:8910 && pnpm --filter bridge dev\" \"wait-on http://localhost:8911 && pnpm --filter runner dev\"",
    "test:e2e": "rm -rf _ && vitest run test/e2e",
    "check": "npm-run-all --parallel typecheck lint format:check",
    "check:fix": "npm-run-all --parallel typecheck lint:fix format:fix",
    "typecheck": "pnpm -r exec tsgo",
    "lint": "oxlint --deny-warnings",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:fix": "oxfmt",
    "format:check": "oxfmt --check",
    "prepare": "husky"
  },
  "devDependencies": {
    "@nkzw/oxlint-config": "1.0.1",
    "@types/node": "^25.3.0",
    "@typescript/native-preview": "7.0.0-dev.20260219.1",
    "concurrently": "^9.2.1",
    "execa": "^9.6.1",
    "husky": "^9.1.7",
    "npm-run-all2": "8.0.4",
    "oxfmt": "0.33.0",
    "oxlint": "1.48.0",
    "tsx": "^4.21.0",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}

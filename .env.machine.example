# Machine-local secrets for the oa-1 local GitHub Actions runner.
# Copy this file to .env.machine and fill in real values.
# .env.machine is gitignored — do NOT commit it.
#
# These values are injected when ${{ secrets.FOO }} expressions
# appear in workflow YAML files run by the local runner.

# Cloudflare (required for vite preview / wrangler in Playwright workflows)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

# Sentry (optional — used for source-map uploads in build workflows)
# SENTRY_DSN=
# VITE_SENTRY_DSN=

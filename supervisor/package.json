{
  "name": "supervisor",
  "version": "1.0.0",
  "description": "Local supervisor for oa-1",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "module",
  "scripts": {
    "build": "tsgo",
    "dev": "node --env-file=.env dist/index.js --config .oa-dev.jsonc",
    "oa": "tsx --env-file=.env src/cli.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@actions/workflow-parser": "0.3.43",
    "dockerode": "^4.0.2",
    "jsonc-parser": "^3.3.1",
    "minimatch": "^10.2.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.34",
    "@types/node": "^22.10.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0"
  },
  "ts-node": {
    "transpileOnly": true,
    "transpiler": "ts-node/transpilers/swc",
    "files": true,
    "compilerOptions": {
      "module": "esnext",
      "isolatedModules": false
    }
  }
}

    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.6",
    "@types/node": "^22.10.2",
    "@types/polka": "^0.5.8",
    "execa": "^9.6.1",
    "tsx": "^4.19.2",
    "vitest": "^4.0.18"
  }
}
